{
  "compilerOptions": {
    "target": "ES2022",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "isolatedModules": true,
    "allowSyntheticDominanceRelations": true,
    "rootDir": "./", 
    "outDir": "./dist"
  }
}
