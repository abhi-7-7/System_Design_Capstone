{
  "name": "system-design-capstone-",
  "version": "1.0.0",
  "description": "Full stack React + Express Monorepo.",
  "type": "module",
  "main": null,
  "scripts": {
    "clean:all": "npm run clean:backend && npm run clean:frontend",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:backend": "npx prisma generate --schema backend/prisma/schema.prisma && tsc --project backend/tsconfig.json && echo 'Backend build complete.'",
    "build:frontend": "npm --prefix frontend run build",
    "build": "npm run build:backend && npm run build:frontend",
    "db:migrate": "npx prisma migrate deploy --schema backend/prisma/schema.prisma",
    "start:all": "npm run clean:all && npm run db:migrate && npm run dev:backend & npm run dev:frontend"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "express": "^4.22.1",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2",
    "vite": "^5.2.10"
  }
}
